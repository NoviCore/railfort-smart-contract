    "migrate:nile":    "node node_modules/tronbox/build/tronbox.js migrate --network nile",
    "migrate:shasta":  "node node_modules/tronbox/build/tronbox.js migrate --network shasta",
    "migrate:mainnet": "node node_modules/tronbox/build/tronbox.js migrate --network mainnet",
    "node:local":      "docker run -d -p 9090:9090 --rm --name tron trontools/quickstart",
    "node:proxy":      "node scripts/tron-proxy.js",
    "pretest":         "node scripts/fund-dev-account.js"
  },
