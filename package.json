  "main": "tronbox.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "compile":         "node node_modules/tronbox/build/tronbox.js compile",
    "test":            "node node_modules/tronbox/build/tronbox.js test --network development",
